# PostgreSQL
NEWS_DB_HOST=postgres
NEWS_DB_PORT=5432
NEWS_DB_NAME=japan_news
NEWS_DB_USER=postgres
NEWS_DB_PASSWORD=change_me
DATABASE_URL=postgresql://postgres:change_me@localhost:5432/japan_news

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# LLM provider (OpenAI-compatible)
# Defaults below match Kimi (Moonshot); override for OpenAI or others.
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_INTENT_MODEL=kimi-k2-0905-preview
LLM_ANSWER_MODEL=kimi-k2-0905-preview
LLM_CLASSIFIER_MODEL=kimi-k2-0905-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Provider examples:
# OpenAI
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_INTENT_MODEL=gpt-4.1-mini
#   LLM_ANSWER_MODEL=gpt-4.1-mini
#   LLM_CLASSIFIER_MODEL=gpt-4.1-mini
# Kimi (Moonshot) — official base is api.moonshot.cn (see platform.kimi.com docs)
#   LLM_BASE_URL=https://api.moonshot.cn/v1
#   LLM_INTENT_MODEL=kimi-k2-0905-preview
#   LLM_ANSWER_MODEL=kimi-k2-0905-preview
#   LLM_CLASSIFIER_MODEL=kimi-k2-0905-preview
# MiniMax
#   LLM_BASE_URL=https://api.minimax.io/v1
#   LLM_INTENT_MODEL=MiniMax-M2.5
#   LLM_ANSWER_MODEL=MiniMax-M2.5
#   LLM_CLASSIFIER_MODEL=MiniMax-M2.5
# DeepSeek
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_INTENT_MODEL=deepseek-chat
#   LLM_ANSWER_MODEL=deepseek-chat
#   LLM_CLASSIFIER_MODEL=deepseek-chat

# Backward-compatible OpenAI variables
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_INTENT_MODEL=gpt-4.1-mini
OPENAI_ANSWER_MODEL=gpt-4.1-mini
OPENAI_CLASSIFIER_MODEL=gpt-4.1-mini

# Airflow core
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=replace_with_32_byte_fernet_key
AIRFLOW_WEBSERVER_SECRET_KEY=replace_with_random_secret
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:change_me@postgres:5432/japan_news
AIRFLOW_WEBSERVER_PORT=8090

# Airflow admin user
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_FIRSTNAME=News
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# ETL runtime
NEWS_ETL_FETCH_LIMIT=50
NEWS_ETL_SOURCE_LANG=ja
NEWS_ETL_TIMEZONE=Asia/Tokyo
NEWS_ETL_QUERY_CACHE_TTL_SECONDS=3600
NEWS_ETL_DEFAULT_LOOKBACK_HOURS=24

# Demo / API
API_BASE_URL=http://localhost:8081/api/query
